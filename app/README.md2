#THIS ISNFOR BACKEND UPGRADE

Recommended PostgreSQL Setup (Local)

Install:

sudo apt install postgresql postgresql-contrib

Create DB:

sudo -u postgres psql
CREATE DATABASE estate_monitor;
CREATE USER estate_user WITH PASSWORD 'strongpassword';
ALTER ROLE estate_user SET client_encoding TO 'utf8';
ALTER ROLE estate_user SET default_transaction_isolation TO 'read committed';
ALTER ROLE estate_user SET timezone TO 'UTC';
GRANT ALL PRIVILEGES ON DATABASE estate_monitor TO estate_user;

Connection string format:

postgresql+psycopg2://estate_user:strongpassword@localhost:5432/estate_monitor
